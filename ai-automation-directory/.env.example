# ---------------------------------------------------------------------------
# AI Automation Agency Directory — environment variables
# Copy this file to `.env.local` for local development, and add the same
# variables in your Vercel project settings for production.
# All values below are placeholders — fill in your own real values.
# ---------------------------------------------------------------------------

# Public canonical base URL of the site (no trailing slash).
# Used for canonical tags, Open Graph URLs, sitemap, and robots.
NEXT_PUBLIC_SITE_URL=https://www.yourdomain.com

# --- Stripe ----------------------------------------------------------------
# Secret key (server-side), looks like "sk_live_..." / "sk_test_...".
# Find it in the Stripe dashboard under Developers > API keys.
STRIPE_SECRET_KEY=your-stripe-secret-key
# Publishable key (client-side, safe to expose), looks like "pk_live_..." / "pk_test_...".
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
# Price IDs for the two listing tiers (create one-time prices in Stripe), look like "price_...".
STRIPE_STANDARD_PRICE_ID=your-standard-price-id
STRIPE_FEATURED_PRICE_ID=your-featured-price-id
# Webhook signing secret for the /api/stripe-webhook endpoint, looks like "whsec_...".
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-signing-secret

# --- Resend (transactional email) ------------------------------------------
# API key from https://resend.com/api-keys (looks like "re_...").
RESEND_API_KEY=your-resend-api-key
# Verified sending address on your verified domain (the "from" address).
RESEND_FROM_EMAIL=hello@yourdomain.com
# Owner address that receives a notification email for each paid submission.
OWNER_EMAIL=you@yourdomain.com
